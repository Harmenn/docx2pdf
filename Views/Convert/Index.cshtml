@using System.Globalization
@model Docx2Pdf.Models.ViewModels.ConversionPageViewModel
@{
    var nl = new CultureInfo("nl-NL");
    ViewData["Title"] = "Converter";
}
<section class="section">
    <div class="container py-5">
        <partial name="_AccountSectionNav" />
        <div class="row g-4 mt-2">
            <div class="col-12 col-lg-5">
                <div class="card-saas">
                    <h1 class="h3 fw-bold mb-3">DOCX uploaden</h1>
                    <p class="text-muted">@Model.ConverterStatusText</p>
                    <p class="small text-muted">Huidig saldo: @Model.CurrentCredits.ToString("N0", nl) credits</p>
                    <form asp-action="Upload" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">DOCX-bestand</label>
                            <input type="file" class="form-control" name="file" accept=".docx" required />
                        </div>
                        <button class="btn btn-primary" type="submit">Start conversie</button>
                    </form>
                </div>
            </div>
            <div class="col-12 col-lg-7">
                <div class="card-saas">
                    <h2 class="h4 fw-bold mb-3">Recente jobs</h2>
                    <div class="table-responsive">
                        <table class="table">
                            <thead><tr><th>ID</th><th>Bestand</th><th>Status</th><th>Tijd</th><th></th></tr></thead>
                            <tbody>
                            @foreach (var job in Model.RecentJobs)
                            {
                                <tr>
                                    <td>#@job.Id</td>
                                    <td>@job.OriginalFileName</td>
                                    <td>@job.Status</td>
                                    <td>@job.CreatedUtc.ToLocalTime().ToString("g", nl)</td>
                                    <td>@if (job.Status == "completed") { <a asp-action="Download" asp-route-id="@job.Id">Download</a> }</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
