@using System.Globalization
@using System.Text.Json
@model Docx2Pdf.Models.ViewModels.HomeViewModel
@{
    var nl = new CultureInfo("nl-NL");
    ViewData["Title"] = "DOCX naar PDF";
    ViewData["MetaTitle"] = "DOCX naar PDF zonder gezeik | Docx2Pdf";
    ViewData["MetaDescription"] = "Drop je DOCX en krijg direct je PDF terug. Geen LibreOffice-circus, geen seat licenses en geen enterprise sales.";
    var pricing = Model.Pricing;
}

<section class="hero hero-bg" id="product">
    <div class="container py-5">
        <div class="row align-items-start g-4">
            <div class="col-12 col-lg-5 reveal">
                <div class="eyebrow">Docx erin. Pdf eruit.</div>
                <h1 class="display-4 fw-bold hero-title hero-title-wide">Drop je DOCX en krijg direct je PDF terug</h1>
                <p class="lead text-muted mt-3">Hoe kan dit anno nu nog steeds zo'n gedoe zijn? Seat licenses, enterprise sales, LibreOffice-workarounds, perpetual licensing, uitzoeken hoeveel mensen er in je team zitten. Onnodig. Hier hoort het simpel te zijn.</p>
                <div class="hero-badges mt-4">
                    <span class="badge-soft">Geen LibreOffice-circus</span>
                    <span class="badge-soft">Geen seats of contractgedoe</span>
                    <span class="badge-soft">Spotgoedkope credits</span>
                </div>
                <div class="hero-ctas d-flex flex-column flex-sm-row gap-2 mt-4">
                    <a class="btn btn-primary btn-lg btn-premium" href="#demo-dropzone">Test de homepage-demo</a>
                    <a class="btn btn-outline-secondary btn-lg btn-premium-link" href="#credits">Bekijk prijzen</a>
                </div>
                <div class="hero-secondary-links mt-3">
                    <a class="link-muted fw-semibold" asp-controller="Convert" asp-action="Index">Of open direct de converter</a>
                </div>
            </div>
            <div class="col-12 col-lg-7 reveal">
                <div class="hero-demo-shell">
                    <div class="hero-drop-panel">
                        <div class="hero-drop-head">
                            <div>
                                <div class="hero-drop-kicker">Direct proberen</div>
                                <div class="hero-drop-title">Kom op, donder die DOCX hier maar neer.</div>
                            </div>
                            <span class="hero-drop-pill">Snelle demo</span>
                        </div>
                        <label class="hero-dropzone" id="demo-dropzone" for="heroDocxInput" tabindex="0">
                            <input id="heroDocxInput" type="file" accept=".docx" hidden />
                            <div class="hero-dropzone-copy">
                                <span class="hero-dropzone-icon" aria-hidden="true">DOCX</span>
                                <strong>Sleep je bestand hierheen</strong>
                                <span>of klik en pak een `.docx` van je schijf</span>
                            </div>
                            <div class="hero-dropzone-meta">
                                <span>Direct downloadgevoel</span>
                                <span>Geen setup-ritueel</span>
                            </div>
                        </label>
                        <div class="hero-drop-console" aria-live="polite">
                            <div class="hero-drop-console-line" id="heroDropStatus">Klaar voor een DOCX. Niet moeilijk doen, gewoon droppen.</div>
                            <div class="hero-drop-console-line is-muted" id="heroDropMeta">Na de drop laten we direct de gewenste UX zien: uploaden, omzetten, downloaden.</div>
                        </div>
                    </div>

                    <div class="hero-proof-strip">
                        <div class="hero-proof-item">
                            <span class="hero-proof-value">1</span>
                            <span class="hero-proof-label">bestand erin</span>
                        </div>
                        <div class="hero-proof-item">
                            <span class="hero-proof-value">1</span>
                            <span class="hero-proof-label">pdf eruit</span>
                        </div>
                        <div class="hero-proof-item">
                            <span class="hero-proof-value">0</span>
                            <span class="hero-proof-label">zin in enterprise-gedoe</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-soft" id="developer-fit">
    <div class="container py-5">
        <div class="section-head reveal">
            <h2 class="h1 fw-bold mb-2">Waar iedereen klaar mee is</h2>
            <p class="text-muted mb-0">De markt maakt van documentconversie veel te vaak een inkooptraject. Dat is precies het probleem dat deze homepage meteen moet afvangen.</p>
        </div>
        <div class="pain-grid mt-4">
            <article class="pain-card reveal">
                <div class="pain-card-label">Niet nodig</div>
                <div class="pain-card-title">Seat licenses en teamformules</div>
                <div class="pain-card-copy">Alsof je eerst een organisatiechart moet invullen voordat een DOCX een PDF mag worden.</div>
            </article>
            <article class="pain-card reveal">
                <div class="pain-card-label">Ook niet nodig</div>
                <div class="pain-card-title">LibreOffice-scriptjes en servergedoe</div>
                <div class="pain-card-copy">Niemand wil discussies over headless setup, fonts, containers en why-is-this-broken-op-prod.</div>
            </article>
            <article class="pain-card reveal">
                <div class="pain-card-label">Helemaal niet nodig</div>
                <div class="pain-card-title">Salescalls voor iets simpels</div>
                <div class="pain-card-copy">Je wilt converteren, niet eerst een offerte aanvragen voor het voorrecht om bestanden om te zetten.</div>
            </article>
        </div>
    </div>
</section>

<section class="section" id="what-you-get">
    <div class="container py-5">
        <div class="section-head reveal">
            <h2 class="h1 fw-bold mb-2">Wat je hier wél krijgt</h2>
            <p class="text-muted mb-0">Focus op de kern van het product: zo snel mogelijk van DOCX naar PDF, met een afrekenmodel dat niet in de weg zit.</p>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt">
                <div class="article-card-link">
                    <div class="article-card-title">Directe flow</div>
                    <div class="article-card-excerpt">Uploaden, verwerken en downloaden horen als één vloeiende actie te voelen. Niet als drie losse systemen aan elkaar geknoopt.</div>
                </div>
            </article>
            <article class="article-card reveal lux-tilt">
                <div class="article-card-link">
                    <div class="article-card-title">Prijs die te snappen is</div>
                    <div class="article-card-excerpt">Credits zijn er om het simpel te houden, niet om extra verwarring toe te voegen. Je ziet meteen waar je aan toe bent.</div>
                </div>
            </article>
            <article class="article-card reveal lux-tilt">
                <div class="article-card-link">
                    <div class="article-card-title">Account pas waar het helpt</div>
                    <div class="article-card-excerpt">Jobhistorie, credits en betalingen zijn er voor overzicht. Niet als hoofdpunt van de productbelofte.</div>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="section section-soft" id="how-it-works">
    <div class="container py-5">
        <div class="section-head reveal">
            <h2 class="h1 fw-bold mb-2">Zo hoort het te voelen</h2>
            <p class="text-muted mb-0">Niet als software die zichzelf belangrijker vindt dan jouw bestand.</p>
        </div>
        <ol class="steps steps-flow mt-4">
            <li class="reveal">
                <span class="step-nr">1</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 1</span>
                    <strong>Drop je DOCX</strong>
                    <span>Geen intake, geen wizard, geen “let's schedule a quick call”. Gewoon het bestand erin.</span>
                </div>
            </li>
            <li class="step-connector reveal" aria-hidden="true"><span>&rarr;</span></li>
            <li class="reveal">
                <span class="step-nr">2</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 2</span>
                    <strong>Laat de conversie zijn werk doen</strong>
                    <span>Zonder dat jij hoeft na te denken over licenties, Office-installaties of welk pakket deze week weer moeilijk doet.</span>
                </div>
            </li>
            <li class="step-connector reveal" aria-hidden="true"><span>&rarr;</span></li>
            <li class="reveal">
                <span class="step-nr">3</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 3</span>
                    <strong>Pak direct je PDF</strong>
                    <span>Dat is de hele belofte. Die moet op de homepage al voelbaar zijn.</span>
                </div>
            </li>
        </ol>
    </div>
</section>

<section id="credits" class="section">
    <div class="container py-5">
        <div class="section-head reveal">
            <h2 class="h1 fw-bold mb-2">Spotgoedkope credits</h2>
            <p class="text-muted mb-0">Niet afrekenen per seat, per team of per onduidelijke enterprise-tier. Gewoon per conversie, helder en goedkoop.</p>
        </div>
        <div class="credit-logic-list mt-3 reveal" aria-label="Uitleg over credits">
            <div>1 conversie = 1 credit</div>
            <div>Geen seats, geen teamlicenties en geen contractgedoe</div>
            <div>Vanaf @pricing.LowestUnitPriceExVat.ToString("C", nl) per credit excl. btw</div>
        </div>

        <div class="credit-slider-shell mt-3 reveal"
             data-min-credits="@pricing.Slider.MinCredits"
             data-max-credits="@pricing.Slider.MaxCredits"
             data-min-price="@pricing.Slider.MinPriceEuro.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-max-price="@pricing.Slider.MaxPriceEuro.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-price-curve-exponent="@pricing.Slider.PriceCurveExponent.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-vat-rate="@pricing.Slider.VatRate.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-quotes-target="pricingQuotes">
            <div class="credit-slider-grid">
                <div class="credit-volume-panel">
                    <div class="credit-slider-copy">
                        <div>
                            <h3 class="h4 fw-bold mb-1">Kies je volume</h3>
                            <p class="text-muted mb-0">Meer volume, lagere prijs per conversie. Zonder dat je eerst hoeft te onderhandelen.</p>
                        </div>
                    </div>
                    <div class="credit-slider-controls">
                        <div class="credit-control-head">
                            <label class="small text-muted d-block mb-0" for="creditVolume">Aantal credits</label>
                            <label class="small text-muted d-block mb-0" for="creditVolumeInput">Exact aantal</label>
                        </div>
                        <div class="credit-control-inputs">
                            <div class="credit-slider-wrap">
                                <input id="creditVolume" class="credit-slider-input" type="range" min="@pricing.Slider.SliderMinCredits" max="@pricing.Slider.SliderMaxPosition" step="1" value="@pricing.Slider.SliderDefaultPosition" aria-describedby="creditVolumeError" />
                                <div class="credit-slider-ticks" aria-hidden="true">
                                    <span class="tick-label tick-label-start" style="--tick-ratio:0;">100</span>
                                    <span class="tick-label tick-label-mid" style="--tick-ratio:0.25;">250</span>
                                    <span class="tick-label tick-label-end" style="--tick-ratio:1;">1.000</span>
                                </div>
                            </div>
                            <div class="credit-input-wrap">
                                <input id="creditVolumeInput" class="credit-number-input" type="text" inputmode="numeric" autocomplete="off" value="@pricing.Slider.DefaultCredits.ToString("N0", nl)" aria-describedby="creditVolumeError" aria-invalid="false" />
                                <span class="credit-input-unit">credits</span>
                            </div>
                        </div>
                        <div class="credit-presets-head">Veelgekozen volumes</div>
                        <div class="credit-presets">
                            <button class="credit-preset" type="button" data-credit-preset="100"><span class="credit-preset-copy"><span class="credit-preset-value">100 credits</span><span class="credit-preset-meta">eerste batch</span></span></button>
                            <button class="credit-preset is-active is-recommended" type="button" data-credit-preset="250"><span class="credit-preset-copy"><span class="credit-preset-value">250 credits</span><span class="credit-preset-meta">lekker starten</span></span><span class="credit-preset-badge">Aanbevolen</span></button>
                            <button class="credit-preset" type="button" data-credit-preset="1000"><span class="credit-preset-copy"><span class="credit-preset-value">1.000 credits</span><span class="credit-preset-meta">laagste prijs</span></span></button>
                        </div>
                        <div id="creditVolumeError" class="credit-input-error" aria-live="polite"></div>
                    </div>
                </div>

                <div class="price pricing-card pricing-card-static price-slider-card reveal" tabindex="0">
                    <div class="price-top">
                        <div><div class="price-name">Directe prijs</div><div class="price-sub">Geen verrassingen, geen contracttaal, gewoon rekenen</div></div>
                        <div class="volume-discount-badge"><span id="creditSliderDiscount">@pricing.DefaultQuote.DiscountPercent</span>% korting</div>
                    </div>
                    <div class="price-value" id="creditSliderSubtotal">@pricing.DefaultQuote.SubtotalExVat.ToString("C", nl)</div>
                    <div class="price-sub"><span id="creditSliderCount">@pricing.Slider.DefaultCredits.ToString("N0", nl)</span> credits geselecteerd</div>
                    <div class="price-per-credit"><strong id="creditSliderUnit">@pricing.DefaultQuote.UnitPriceExVat.ToString("C", nl)</strong> per credit excl. btw</div>
                    <div class="price-summary-note">Eenmalig inkopen, direct gebruiken</div>
                    <div class="price-meta">
                        <div class="price-meta-row"><span class="k">Aantal credits</span><span class="v" id="creditSliderCountMeta">@pricing.Slider.DefaultCredits.ToString("N0", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Prijs per credit</span><span class="v" id="creditSliderUnitMeta">@pricing.DefaultQuote.UnitPriceExVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Subtotaal excl. btw</span><span class="v" id="creditSliderSubtotalMeta">@pricing.DefaultQuote.SubtotalExVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Btw</span><span class="v" id="creditSliderVat">@pricing.DefaultQuote.VatAmount.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Totaal incl. btw</span><span class="v" id="creditSliderTotal">@pricing.DefaultQuote.TotalInclVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Volumevoordeel</span><span class="v" id="creditSliderDiscountMeta">@pricing.DefaultQuote.DiscountPercent%</span></div>
                    </div>
                    <a id="creditOverviewCta" class="btn btn-primary w-100" href="/credits/summary?credits=@pricing.Slider.DefaultCredits">Kies credits en ga door</a>
                </div>
            </div>
        </div>
        <script id="pricingQuotes" type="application/json">@Html.Raw(JsonSerializer.Serialize(pricing.QuoteOptions.Select(x => new { credits = x.Credits, sliderPosition = x.SliderPosition, unitPriceExVat = x.UnitPriceExVat, subtotalExVat = x.SubtotalExVat, vatAmount = x.VatAmount, totalInclVat = x.TotalInclVat, discountPercent = x.DiscountPercent })))</script>
    </div>
</section>
