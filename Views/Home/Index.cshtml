@using System.Globalization
@using System.Text.Json
@model Docx2Pdf.Models.ViewModels.HomeViewModel
@{
    var nl = new CultureInfo("nl-NL");
    ViewData["Title"] = "DOCX naar PDF starter";
    ViewData["MetaTitle"] = "DOCX naar PDF starter voor developers op Windows | Docx2Pdf";
    ViewData["MetaDescription"] = "Start sneller met een Windows-first DOCX naar PDF starter: uploads, accounts, credits, Mollie en admin zijn al gebouwd.";
    var pricing = Model.Pricing;
}

<section class="hero hero-bg" id="product">
    <div class="container py-5">
        <div class="row align-items-start g-4">
            <div class="col-12 col-lg-6 reveal">
                <div class="eyebrow">Voor developers die nu een docx2pdf dienst willen opzetten</div>
                <h1 class="display-5 fw-bold hero-title">Bouw sneller een DOCX naar PDF dienst op Windows, zonder auth, billing en jobbeheer zelf opnieuw te maken</h1>
                <p class="lead text-muted mt-3">Deze app is geen generieke marketingdemo, maar een starter voor developers. Uploads, accounts, credits, Mollie en admin staan al. Jij koppelt alleen nog de daadwerkelijke DOCX naar PDF engine.</p>
                <div class="credit-logic-list hero-quick-facts mt-4">
                    <div>ASP.NET Core 9 + PostgreSQL basis staat al</div>
                    <div>Upload DOCX, sla jobs op en reken per conversie credits af</div>
                    <div>Mollie checkout en adminbeheer zijn al aangesloten</div>
                </div>
                <div class="hero-ctas d-flex flex-column flex-sm-row gap-2 mt-4">
                    <a class="btn btn-primary btn-lg btn-premium" asp-controller="Convert" asp-action="Index">Bekijk de converterflow</a>
                    <a class="btn btn-outline-secondary btn-lg btn-premium-link" href="#developer-fit">Past dit bij jouw use case?</a>
                </div>
                <div class="hero-secondary-links mt-3">
                    <a class="link-muted fw-semibold" href="#what-you-get">Bekijk wat al gebouwd is</a>
                </div>
            </div>
            <div class="col-12 col-lg-6 reveal">
                <div class="hero-demo">
                    <div class="card-saas">
                        <div class="card-saas-head">
                            <div class="d-flex align-items-center gap-2">
                                <span class="dot dot-red"></span><span class="dot dot-yellow"></span><span class="dot dot-green"></span>
                            </div>
                            <span class="pill">Wat jij nog hoeft te doen</span>
                        </div>
                        <div class="codebox codebox-response mt-3">
<pre class="m-0"><code>{
  "input": "contract.docx",
  "status": "configuration_required",
  "creditsRequired": 1,
  "provider": "placeholder",
  "nextStep": "implementeer IDocumentConversionEngine"
}</code></pre>
                        </div>
                        <div class="mt-4 small text-muted">
                            Kort gezegd: de productschil is klaar. De conversiekern is het enige stuk dat je nog hoeft te implementeren.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-soft" id="developer-fit">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Voor wie dit wel en niet handig is</h2>
            <p class="text-muted mb-0">Zo weet je in 10 seconden of dit je echt verder helpt.</p>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Handig als je snel wilt shippen</div><div class="article-card-excerpt">Je wilt niet opnieuw beginnen met login, credits, payments, uploads, jobstatus en admin.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Minder handig als je alleen een losse library zoekt</div><div class="article-card-excerpt">Zoek je alleen een pure converter zonder webapp, billing of accounts, dan is dit fundament zwaarder dan nodig.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Gemaakt voor Windows-first flows</div><div class="article-card-excerpt">De app is opgezet voor een Windows-omgeving waar jij zelf de uiteindelijke conversietechniek achter hangt.</div></article>
        </div>
    </div>
</section>

<section class="section" id="what-you-get">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Wat je direct krijgt</h2>
            <p class="text-muted mb-0">Dit zijn de stukken die al gebouwd zijn en waar je dus geen tijd meer aan hoeft te verliezen.</p>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Accounts en rechten</div><div class="article-card-excerpt">Registratie, login, accountoverzicht en adminrol zitten al in de stack.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Credits en checkout</div><div class="article-card-excerpt">Koop credits via Mollie, verwerk intents/webhooks en houd betaalgeschiedenis en facturen bij.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Upload en conversiejobs</div><div class="article-card-excerpt">DOCX uploaden, jobs opslaan, statuses tonen, fouten afhandelen en outputbestanden koppelen.</div></article>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Admin tooling</div><div class="article-card-excerpt">Users bekijken, credits ophogen en recente jobs en payments controleren.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Trackingbasis</div><div class="article-card-excerpt">Visitor- en sessiontracking voor productinzichten en supportcontext.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Verse database en migraties</div><div class="article-card-excerpt">Nieuwe PostgreSQL-setup met opgeschoond schema dat alleen op dit product gericht is.</div></article>
        </div>
    </div>
</section>

<section class="section">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Hoe je dit als developer gebruikt</h2>
            <p class="text-muted mb-0">Geen salespraat. Gewoon de snelste route naar een werkende dienst.</p>
        </div>
        <ol class="steps steps-flow mt-4">
            <li class="reveal">
                <span class="step-nr">1</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 1</span>
                    <strong>Gebruik de bestaande productflow</strong>
                    <span>Laat users registreren, credits kopen en DOCX-bestanden uploaden zonder eerst alle randzaken zelf te bouwen.</span>
                </div>
            </li>
            <li class="step-connector reveal" aria-hidden="true"><span>&rarr;</span></li>
            <li class="reveal">
                <span class="step-nr">2</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 2</span>
                    <strong>Implementeer je converter op 1 plek</strong>
                    <span>Koppel jouw Word-, LibreOffice- of andere Windows-flow achter `IDocumentConversionEngine`.</span>
                </div>
            </li>
            <li class="step-connector reveal" aria-hidden="true"><span>&rarr;</span></li>
            <li class="reveal">
                <span class="step-nr">3</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 3</span>
                    <strong>Lever output terug in de bestaande jobflow</strong>
                    <span>De app handelt credits, statussen, downloads en accountgeschiedenis daarna al voor je af.</span>
                </div>
            </li>
        </ol>
    </div>
</section>

<section id="credits" class="section">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Credits voor conversies</h2>
            <p class="text-muted mb-0">De creditstructuur zit al in de flow. Gebruik dit als basis als je per conversie wilt afrekenen.</p>
        </div>

        <div class="credit-slider-shell mt-3 reveal"
             data-min-credits="@pricing.Slider.MinCredits"
             data-max-credits="@pricing.Slider.MaxCredits"
             data-min-price="@pricing.Slider.MinPriceEuro.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-max-price="@pricing.Slider.MaxPriceEuro.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-price-curve-exponent="@pricing.Slider.PriceCurveExponent.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-vat-rate="@pricing.Slider.VatRate.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-quotes-target="pricingQuotes">
            <div class="credit-slider-grid">
                <div class="credit-volume-panel">
                    <div class="credit-slider-copy">
                        <div>
                            <h3 class="h4 fw-bold mb-1">Kies je volume</h3>
                            <p class="text-muted mb-0">Elke succesvolle conversie kan 1 credit verbruiken.</p>
                        </div>
                    </div>
                    <div class="credit-slider-controls">
                        <div class="credit-control-head">
                            <label class="small text-muted d-block mb-0" for="creditVolume">Aantal credits</label>
                            <label class="small text-muted d-block mb-0" for="creditVolumeInput">Exact aantal</label>
                        </div>
                        <div class="credit-control-inputs">
                            <div class="credit-slider-wrap">
                                <input id="creditVolume" class="credit-slider-input" type="range" min="@pricing.Slider.SliderMinCredits" max="@pricing.Slider.SliderMaxPosition" step="1" value="@pricing.Slider.SliderDefaultPosition" />
                            </div>
                            <div class="credit-input-wrap">
                                <input id="creditVolumeInput" class="credit-number-input" type="text" inputmode="numeric" value="@pricing.Slider.DefaultCredits.ToString("N0", nl)" />
                                <span class="credit-input-unit">credits</span>
                            </div>
                        </div>
                        <div class="credit-presets">
                            <button class="credit-preset" type="button" data-credit-preset="100"><span class="credit-preset-copy"><span class="credit-preset-value">100 credits</span><span class="credit-preset-meta">testbatch</span></span></button>
                            <button class="credit-preset is-active is-recommended" type="button" data-credit-preset="250"><span class="credit-preset-copy"><span class="credit-preset-value">250 credits</span><span class="credit-preset-meta">startpakket</span></span><span class="credit-preset-badge">Aanbevolen</span></button>
                            <button class="credit-preset" type="button" data-credit-preset="1000"><span class="credit-preset-copy"><span class="credit-preset-value">1.000 credits</span><span class="credit-preset-meta">lagere prijs</span></span></button>
                        </div>
                        <div id="creditVolumeError" class="credit-input-error" aria-live="polite"></div>
                    </div>
                </div>

                <div class="price pricing-card pricing-card-static price-slider-card reveal">
                    <div class="price-top">
                        <div><div class="price-name">Voorbeeld pricing</div><div class="price-sub">Pas volumes en prijzen later aan zonder de checkoutflow te herschrijven</div></div>
                        <div class="volume-discount-badge"><span id="creditSliderDiscount">@pricing.DefaultQuote.DiscountPercent</span>% korting</div>
                    </div>
                    <div class="price-value" id="creditSliderSubtotal">@pricing.DefaultQuote.SubtotalExVat.ToString("C", nl)</div>
                    <div class="price-sub"><span id="creditSliderCount">@pricing.Slider.DefaultCredits.ToString("N0", nl)</span> credits geselecteerd</div>
                    <div class="price-per-credit"><strong id="creditSliderUnit">@pricing.DefaultQuote.UnitPriceExVat.ToString("C", nl)</strong> per credit excl. btw</div>
                    <div class="price-meta">
                        <div class="price-meta-row"><span class="k">Aantal credits</span><span class="v" id="creditSliderCountMeta">@pricing.Slider.DefaultCredits.ToString("N0", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Prijs per credit</span><span class="v" id="creditSliderUnitMeta">@pricing.DefaultQuote.UnitPriceExVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Subtotaal excl. btw</span><span class="v" id="creditSliderSubtotalMeta">@pricing.DefaultQuote.SubtotalExVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Btw</span><span class="v" id="creditSliderVat">@pricing.DefaultQuote.VatAmount.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Totaal incl. btw</span><span class="v" id="creditSliderTotal">@pricing.DefaultQuote.TotalInclVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Volumevoordeel</span><span class="v" id="creditSliderDiscountMeta">@pricing.DefaultQuote.DiscountPercent%</span></div>
                    </div>
                    <a id="creditOverviewCta" class="btn btn-primary w-100" href="/credits/summary?credits=@pricing.Slider.DefaultCredits">Bekijk checkoutflow</a>
                </div>
            </div>
        </div>
        <script id="pricingQuotes" type="application/json">@Html.Raw(JsonSerializer.Serialize(pricing.QuoteOptions.Select(x => new { credits = x.Credits, sliderPosition = x.SliderPosition, unitPriceExVat = x.UnitPriceExVat, subtotalExVat = x.SubtotalExVat, vatAmount = x.VatAmount, totalInclVat = x.TotalInclVat, discountPercent = x.DiscountPercent })))</script>
    </div>
</section>

<section class="section section-soft">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Wat nog ontbreekt</h2>
            <p class="text-muted mb-0">Dit is het enige stuk dat een developer nog zelf moet invullen.</p>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">De converter-engine</div><div class="article-card-excerpt">De daadwerkelijke DOCX naar PDF omzetting is nog niet geïmplementeerd. Dat haakt aan op één interface in de backend.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Jouw technische keuze</div><div class="article-card-excerpt">Je bepaalt zelf of je Word automation, LibreOffice of een andere Windows-aanpak gebruikt.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Belangrijk voor je planning</div><div class="article-card-excerpt">Zoek je vandaag alleen een kant-en-klare converter, dan is dit niet de eindoplossing maar een productstarter.</div></article>
        </div>
    </div>
</section>
