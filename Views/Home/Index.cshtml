@using System.Globalization
@using System.Text.Json
@model Docx2Pdf.Models.ViewModels.HomeViewModel
@{
    var nl = new CultureInfo("nl-NL");
    ViewData["Title"] = "DOCX naar PDF API";
    ViewData["MetaTitle"] = "DOCX naar PDF API met credits en accountflow | Docx2Pdf";
    ViewData["MetaDescription"] = "Zet DOCX om naar PDF via een duidelijke creditflow, accountomgeving en joboverzicht. Gemaakt voor teams die documentconversie willen aanbieden zonder onnodige rompslomp.";
    var pricing = Model.Pricing;
}

<section class="hero hero-bg" id="product">
    <div class="container py-5">
        <div class="row align-items-start g-4">
            <div class="col-12 col-lg-6 reveal">
                <div class="eyebrow">Documentconversie zonder onduidelijke pricing of losse tools</div>
                <h1 class="display-5 fw-bold hero-title">DOCX naar PDF met account, credits en een duidelijke conversieflow</h1>
                <p class="lead text-muted mt-3">Voor teams die documentconversie als dienst willen aanbieden. Upload een DOCX-bestand, volg de jobstatus, reken af per credit en beheer alles vanuit één accountomgeving.</p>
                <div class="credit-logic-list hero-quick-facts mt-4">
                    <div>1 uploadflow voor DOCX naar PDF</div>
                    <div>1 credit per succesvolle conversie</div>
                    <div>Credits, betalingen en jobhistorie in hetzelfde product</div>
                </div>
                <div class="hero-ctas d-flex flex-column flex-sm-row gap-2 mt-4">
                    <a class="btn btn-primary btn-lg btn-premium" asp-area="Identity" asp-page="/Account/Register">Maak account en test de flow</a>
                    <a class="btn btn-outline-secondary btn-lg btn-premium-link" asp-controller="Convert" asp-action="Index">Bekijk de converter</a>
                </div>
                <div class="hero-secondary-links mt-3">
                    <a class="link-muted fw-semibold" href="#how-it-works">Bekijk hoe het werkt</a>
                </div>
            </div>
            <div class="col-12 col-lg-6 reveal">
                <div class="hero-demo">
                    <div class="card-saas">
                        <div class="card-saas-head">
                            <div class="d-flex align-items-center gap-2">
                                <span class="dot dot-red"></span><span class="dot dot-yellow"></span><span class="dot dot-green"></span>
                            </div>
                            <span class="pill">Voorbeeld jobstatus</span>
                        </div>
                        <div class="codebox codebox-response mt-3">
<pre class="m-0"><code>{
  "input": "contract.docx",
  "status": "configuration_required",
  "creditsRequired": 1,
  "provider": "placeholder",
  "nextStep": "job wacht op actieve conversie-engine"
}</code></pre>
                        </div>
                        <div class="mt-4 small text-muted">
                            De flow voor account, credits, jobs en downloads staat. De daadwerkelijke conversie-engine is nog het open onderdeel.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section section-soft" id="developer-fit">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Waarom teams hiervoor kiezen</h2>
            <p class="text-muted mb-0">Niet omdat het mooi klinkt, maar omdat het operationele gedoe rondom documentconversie snel onnodig groot wordt.</p>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Duidelijke afrekening</div><div class="article-card-excerpt">Geen vage offerteflow. Je ziet direct hoeveel credits je koopt en wat een conversie kost.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Minder handwerk</div><div class="article-card-excerpt">Gebruikers, betalingen, uploads, statussen en downloads zitten in dezelfde flow in plaats van verspreid over losse tools.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Beter overzicht</div><div class="article-card-excerpt">Accounts zien hun eigen jobs en credits terug. Beheer kan users en volume centraal volgen.</div></article>
        </div>
    </div>
</section>

<section class="section" id="what-you-get">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Wat er nu in het product zit</h2>
            <p class="text-muted mb-0">Alleen functies die daadwerkelijk in deze build aanwezig zijn.</p>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Accountomgeving</div><div class="article-card-excerpt">Registreren, inloggen, creditsaldo bekijken en recente conversies terugzien in je eigen account.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Credits en betalingen</div><div class="article-card-excerpt">Credits kopen via Mollie, betaalstatus volgen en facturen terugvinden vanuit dezelfde flow.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Upload en jobtracking</div><div class="article-card-excerpt">DOCX-bestanden uploaden, status van jobs volgen en outputbestanden klaarmaken voor download.</div></article>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Adminbeheer</div><div class="article-card-excerpt">Users bekijken, credits ophogen en recente jobs en betalingen controleren vanuit één adminpagina.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Volume-structuur</div><div class="article-card-excerpt">Een staffelmodel voor credits is aanwezig, zodat je prijs per conversie direct kunt sturen.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Jobhistorie per gebruiker</div><div class="article-card-excerpt">Niet alleen converteren, maar ook terugzien wat eerder is geüpload en wat de status daarvan was.</div></article>
        </div>
    </div>
</section>

<section class="section" id="how-it-works">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Hoe de flow werkt</h2>
            <p class="text-muted mb-0">Dit is wat een gebruiker of klant logisch doorloopt.</p>
        </div>
        <ol class="steps steps-flow mt-4">
            <li class="reveal">
                <span class="step-nr">1</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 1</span>
                    <strong>Maak een account en koop credits</strong>
                    <span>Gebruikers starten met een account en zien direct welk volume ze nodig hebben.</span>
                </div>
            </li>
            <li class="step-connector reveal" aria-hidden="true"><span>&rarr;</span></li>
            <li class="reveal">
                <span class="step-nr">2</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 2</span>
                    <strong>Upload een DOCX-bestand</strong>
                    <span>Het bestand komt in een conversiejob terecht, zodat status, foutafhandeling en download logisch op één plek zitten.</span>
                </div>
            </li>
            <li class="step-connector reveal" aria-hidden="true"><span>&rarr;</span></li>
            <li class="reveal">
                <span class="step-nr">3</span>
                <div class="step-copy">
                    <span class="step-kicker">Stap 3</span>
                    <strong>Download de PDF zodra de job klaar is</strong>
                    <span>Credits, jobhistorie en outputbestanden blijven daarna zichtbaar in het account en beheer.</span>
                </div>
            </li>
        </ol>
    </div>
</section>

<section id="credits" class="section">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Credits voor conversies</h2>
            <p class="text-muted mb-0">Heldere volumeprijzen helpen prospects sneller beslissen dan een onzichtbare sales- of offerteflow.</p>
        </div>

        <div class="credit-slider-shell mt-3 reveal"
             data-min-credits="@pricing.Slider.MinCredits"
             data-max-credits="@pricing.Slider.MaxCredits"
             data-min-price="@pricing.Slider.MinPriceEuro.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-max-price="@pricing.Slider.MaxPriceEuro.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-price-curve-exponent="@pricing.Slider.PriceCurveExponent.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-vat-rate="@pricing.Slider.VatRate.ToString(System.Globalization.CultureInfo.InvariantCulture)"
             data-quotes-target="pricingQuotes">
            <div class="credit-slider-grid">
                <div class="credit-volume-panel">
                    <div class="credit-slider-copy">
                        <div>
                            <h3 class="h4 fw-bold mb-1">Kies je volume</h3>
                            <p class="text-muted mb-0">Elke succesvolle conversie kan 1 credit verbruiken.</p>
                        </div>
                    </div>
                    <div class="credit-slider-controls">
                        <div class="credit-control-head">
                            <label class="small text-muted d-block mb-0" for="creditVolume">Aantal credits</label>
                            <label class="small text-muted d-block mb-0" for="creditVolumeInput">Exact aantal</label>
                        </div>
                        <div class="credit-control-inputs">
                            <div class="credit-slider-wrap">
                                <input id="creditVolume" class="credit-slider-input" type="range" min="@pricing.Slider.SliderMinCredits" max="@pricing.Slider.SliderMaxPosition" step="1" value="@pricing.Slider.SliderDefaultPosition" />
                            </div>
                            <div class="credit-input-wrap">
                                <input id="creditVolumeInput" class="credit-number-input" type="text" inputmode="numeric" value="@pricing.Slider.DefaultCredits.ToString("N0", nl)" />
                                <span class="credit-input-unit">credits</span>
                            </div>
                        </div>
                        <div class="credit-presets">
                            <button class="credit-preset" type="button" data-credit-preset="100"><span class="credit-preset-copy"><span class="credit-preset-value">100 credits</span><span class="credit-preset-meta">testbatch</span></span></button>
                            <button class="credit-preset is-active is-recommended" type="button" data-credit-preset="250"><span class="credit-preset-copy"><span class="credit-preset-value">250 credits</span><span class="credit-preset-meta">startpakket</span></span><span class="credit-preset-badge">Aanbevolen</span></button>
                            <button class="credit-preset" type="button" data-credit-preset="1000"><span class="credit-preset-copy"><span class="credit-preset-value">1.000 credits</span><span class="credit-preset-meta">lagere prijs</span></span></button>
                        </div>
                        <div id="creditVolumeError" class="credit-input-error" aria-live="polite"></div>
                    </div>
                </div>

                <div class="price pricing-card pricing-card-static price-slider-card reveal">
                    <div class="price-top">
                        <div><div class="price-name">Directe prijs</div><div class="price-sub">Gebruik dit als uitgangspunt voor je creditmodel</div></div>
                        <div class="volume-discount-badge"><span id="creditSliderDiscount">@pricing.DefaultQuote.DiscountPercent</span>% korting</div>
                    </div>
                    <div class="price-value" id="creditSliderSubtotal">@pricing.DefaultQuote.SubtotalExVat.ToString("C", nl)</div>
                    <div class="price-sub"><span id="creditSliderCount">@pricing.Slider.DefaultCredits.ToString("N0", nl)</span> credits geselecteerd</div>
                    <div class="price-per-credit"><strong id="creditSliderUnit">@pricing.DefaultQuote.UnitPriceExVat.ToString("C", nl)</strong> per credit excl. btw</div>
                    <div class="price-meta">
                        <div class="price-meta-row"><span class="k">Aantal credits</span><span class="v" id="creditSliderCountMeta">@pricing.Slider.DefaultCredits.ToString("N0", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Prijs per credit</span><span class="v" id="creditSliderUnitMeta">@pricing.DefaultQuote.UnitPriceExVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Subtotaal excl. btw</span><span class="v" id="creditSliderSubtotalMeta">@pricing.DefaultQuote.SubtotalExVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Btw</span><span class="v" id="creditSliderVat">@pricing.DefaultQuote.VatAmount.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Totaal incl. btw</span><span class="v" id="creditSliderTotal">@pricing.DefaultQuote.TotalInclVat.ToString("C", nl)</span></div>
                        <div class="price-meta-row"><span class="k">Volumevoordeel</span><span class="v" id="creditSliderDiscountMeta">@pricing.DefaultQuote.DiscountPercent%</span></div>
                    </div>
                    <a id="creditOverviewCta" class="btn btn-primary w-100" href="/credits/summary?credits=@pricing.Slider.DefaultCredits">Bekijk aankoopoverzicht</a>
                </div>
            </div>
        </div>
        <script id="pricingQuotes" type="application/json">@Html.Raw(JsonSerializer.Serialize(pricing.QuoteOptions.Select(x => new { credits = x.Credits, sliderPosition = x.SliderPosition, unitPriceExVat = x.UnitPriceExVat, subtotalExVat = x.SubtotalExVat, vatAmount = x.VatAmount, totalInclVat = x.TotalInclVat, discountPercent = x.DiscountPercent })))</script>
    </div>
</section>

<section class="section section-soft">
    <div class="container py-5">
        <div class="section-head section-head-centered reveal">
            <h2 class="h1 fw-bold mb-2">Wat nog ontbreekt</h2>
            <p class="text-muted mb-0">De homepage moet eerlijk blijven over wat deze build nu wel en niet kan.</p>
        </div>
        <div class="articles-grid mt-4">
            <article class="article-card reveal lux-tilt"><div class="article-card-title">De daadwerkelijke omzetting</div><div class="article-card-excerpt">De conversie-engine achter de jobflow is nog niet actief. Daardoor is de gebruikersflow wel zichtbaar, maar de uiteindelijke omzetting nog niet live.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Nog geen publieke API-endpoints</div><div class="article-card-excerpt">De huidige build toont vooral de account-, billing- en uploadflow. Een publieke API-laag voor integrerende klanten is nog geen onderdeel van deze versie.</div></article>
            <article class="article-card reveal lux-tilt"><div class="article-card-title">Belangrijk voor verwachtingen</div><div class="article-card-excerpt">Zoek je vandaag een volledig werkende docx2pdf API, dan is de propositie nog niet af en moet die technische laag nog worden toegevoegd.</div></article>
        </div>
    </div>
</section>
